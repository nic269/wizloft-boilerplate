{
	"name": "@repo/database",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./client": "./src/client.ts",
		"./keys": "./src/keys.ts"
	},
	"scripts": {
		"build": "dotenv -e ../../.env -- prisma generate",
		"check-types": "tsc --noEmit",
		"generate": "dotenv -e ../../.env -- prisma generate",
		"db:push": "dotenv -e ../../.env -- prisma db push",
		"db:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
		"db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
		"db:seed": "dotenv -e ../../.env -- tsx src/seed.ts",
		"db:studio": "dotenv -e ../../.env -- prisma studio",
		"test": "vitest run --passWithNoTests",
		"test:unit": "vitest run --passWithNoTests",
		"test:integration": "echo 'database integration tests require a test database'"
	},
	"dependencies": {
		"@prisma/client": "^6.19.1",
		"@t3-oss/env-core": "^0.13.10",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@repo/typescript-config": "workspace:*",
		"prisma": "^6.19.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vitest": "^4.0.18"
	}
}
