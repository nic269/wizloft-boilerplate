NODE_ENV=development

# Core local URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WEB_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3002
APP_INTERNAL_URL=http://localhost:3000
API_INTERNAL_URL=http://localhost:3002

# Required core services
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/personal_saas_boilerplate
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:3002/api/auth

# Optional auth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional mail
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SMTP_URL=

# Optional billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Optional observability and analytics
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=

# Optional storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=.data/storage
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
