{
  "name": "personal-saas-boilerplate",
  "version": "0.1.0",
  "private": true,
  "author": "Anh Nguyen",
  "license": "MIT",
  "description": "A reusable personal SaaS boilerplate monorepo for production-ready apps.",
  "type": "module",
  "packageManager": "pnpm@10.4.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma",
    "seed": "tsx packages/database/src/seed.ts"
  },
  "scripts": {
    "build": "dotenv -e .env -- turbo run build",
    "dev": "dotenv -e .env -- turbo run dev",
    "check": "ultracite fix",
    "check:ci": "ultracite check",
    "check-types": "turbo run check-types",
    "test": "dotenv -e .env -- turbo run test",
    "test:unit": "dotenv -e .env -- turbo run test:unit",
    "test:integration": "dotenv -e .env -- turbo run test:integration",
    "test:e2e": "dotenv -e .env -- playwright test",
    "test:e2e:db": "node scripts/e2e-with-db.mjs",
    "release:check": "pnpm templates:validate && pnpm check:ci && pnpm check-types && pnpm test && pnpm boundaries && pnpm build",
    "templates:list": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/template-catalog.ts list",
    "templates:json": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/template-catalog.ts json",
    "templates:validate": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/template-catalog.ts validate",
    "db:generate": "pnpm --filter @repo/database generate",
    "db:push": "pnpm --filter @repo/database db:push",
    "db:migrate:dev": "pnpm --filter @repo/database db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @repo/database db:migrate:deploy",
    "db:seed": "pnpm --filter @repo/database db:seed",
    "db:studio": "pnpm --filter @repo/database db:studio",
    "boundaries": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/check-boundaries.ts",
    "clean": "pnpm clean:build",
    "clean:build": "pnpm -r exec rm -rf dist .next storybook-static && pnpm exec rm -rf .turbo test-results playwright-report",
    "clean:deps": "pnpm -r exec rm -rf node_modules && pnpm exec rm -rf node_modules",
    "upgrade:deps": "pnpm up --latest -r && pnpm up --latest",
    "ui:gen": "pnpm --filter @repo/design-system gen-components"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@playwright/test": "^1.57.0",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.19.0",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "ultracite": "7.2.5",
    "vitest": "^4.0.18"
  }
}
