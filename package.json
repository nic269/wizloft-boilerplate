{
	"name": "personal-saas-boilerplate",
	"version": "0.1.0",
	"private": true,
	"author": "Anh Nguyen",
	"license": "MIT",
	"description": "A reusable personal SaaS boilerplate monorepo for production-ready apps.",
	"type": "module",
	"packageManager": "pnpm@10.4.0",
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"prisma": {
		"schema": "packages/database/prisma/schema.prisma",
		"seed": "tsx packages/database/src/seed.ts"
	},
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"check": "biome check --write .",
		"check:ci": "biome check .",
		"check-types": "turbo run check-types",
		"test": "turbo run test",
		"test:unit": "turbo run test:unit",
		"test:integration": "turbo run test:integration",
		"test:e2e": "playwright test",
		"db:generate": "pnpm --filter @repo/database generate",
		"db:push": "pnpm --filter @repo/database db:push",
		"db:migrate:dev": "pnpm --filter @repo/database db:migrate:dev",
		"db:migrate:deploy": "pnpm --filter @repo/database db:migrate:deploy",
		"db:seed": "pnpm --filter @repo/database db:seed",
		"boundaries": "tsx scripts/check-boundaries.ts",
		"clean": "git clean -xdf node_modules .turbo apps/*/.next packages/*/dist"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@playwright/test": "^1.57.0",
		"@repo/typescript-config": "workspace:*",
		"@types/node": "^22.19.0",
		"tsx": "^4.21.0",
		"turbo": "^2.9.6",
		"typescript": "^6.0.3",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"zod": "^4.3.6"
	}
}
